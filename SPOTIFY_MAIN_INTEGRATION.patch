++
++        return com.metrolist.spotify.models.SpotifyHomeFeedItem.Album(
++            uri = uri,
++            id = uri.substringAfterLast(":"),
++            name = data.str("name") ?: "",
++            albumType = data.str("type")?.lowercase(),
