<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/widget_background.xml -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    
    <!-- Base fallback color: transparent white adjusted to 35% opacity -->
    <solid android:color="#59FFFFFF" />
    
    <!-- Rounded corners conforming to standard modern Android specifications -->
    <corners android:radius="24dp" />
    
    <!-- Ultra thin translucent border adjusted to match the 35% depth opacity -->
    <stroke 
        android:width="1.5dp" 
        android:color="#59FFFFFF" />
</shape>
